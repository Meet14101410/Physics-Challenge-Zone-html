body {
  font-family: Arial, sans-serif;
  text-align: center;
  background-color: #e6f2ff;
}

h1 {
  color: #003366;
  margin-top: 40px;
}

p {
  font-size: 18px;
  color: #333;
}

button {
  margin: 8px;
  padding: 10px 18px;
  font-size: 16px;
  border: none;
  border-radius: 6px;
  background-color: #0073e6;
  color: white;
  cursor: pointer;
}

button:hover {
  background-color: #0059b3;
}

#result {
  font-weight: bold;
  margin-top: 15px;
}
